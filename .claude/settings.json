{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(python3 -m http.server *)",
      "Bash(python3 -c *)",
      "Bash(python3 *.py)",
      "Bash(node -e *)",
      "Bash(node --check *)",
      "Bash(python3 -m json.tool *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(echo *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(npm install *)",
      "Read(.claude/settings.local.json)",
      "Read(CLAUDE.local.md)"
    ]
  },

  "env": {
    "PYTHONDONTWRITEBYTECODE": "1"
  }
}
